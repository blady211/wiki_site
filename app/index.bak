<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>IT Knowledge Hub</title>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css/github-markdown.min.css">

<style>
body{margin:0;font-family:system-ui;background:#0f172a;color:#e5e7eb}
.layout{display:flex;height:100vh}

/* SIDEBAR */
.sidebar{
  width:280px;background:#020617;border-right:1px solid #1e293b;
  padding:18px;overflow-y:auto
}

/* SEARCH */
#search{
  width:100%;padding:8px 10px;margin-bottom:14px;
  border-radius:8px;border:1px solid #1e293b;
  background:#0b1220;color:#e5e7eb
}

/* TREE */
.tree-folder{
  cursor:pointer;
  color:#94a3b8;
  font-size:13px;
  text-transform:uppercase;
  margin:14px 0 4px;
  display:flex;
  align-items:center;
  gap:6px;
}

.tree-sub{
  margin-left:12px;
  display:none;
}

.tree-sub.open{
  display:block;
}

.tree-file{
  display:block;
  background:none;
  border:none;
  color:#cbd5f5;
  padding:6px 8px;
  cursor:pointer;
  border-radius:6px;
  font-size:14px;
  width:100%;
  text-align:left;
}

.tree-file:hover{
  background:rgba(56,189,248,.15);
}

.tree-file.active{
  background:rgba(56,189,248,.25);
  color:#fff;
}

/* CONTENT */
.content{flex:1;padding:32px;overflow-y:auto}
.markdown-body{background:#0b1220;padding:32px;border-radius:10px;max-width:900px}

/* TOC */
.toc{
  width:220px;border-left:1px solid #1e293b;padding:18px;
  overflow-y:auto;background:#020617
}
.toc h3{margin-top:0;font-size:13px;color:#94a3b8;text-transform:uppercase}
.toc a{display:block;color:#94a3b8;text-decoration:none;padding:4px 0;font-size:13px}
.toc a:hover{color:#38bdf8}

</style>
</head>

<body>

<div class="layout">

  <div class="sidebar">
    <input id="search" placeholder="Search (* wildcard)" oninput="searchDocs()">
    <div id="menu"></div>
  </div>

  <div class="content">
    <div id="content" class="markdown-body">
      <h1>IT Knowledge Hub</h1>
      <p>Select document.</p>
    </div>
  </div>

  <div class="toc">
    <h3>On this page</h3>
    <div id="toc"></div>
  </div>

</div>

<script>
const repo="blady211/wiki_site";
const folders=["self-learning","interview","projects"];

let indexCache=[];

/* ---------- INIT ---------- */
init();

async function init(){
  const menu=document.getElementById("menu");
  menu.innerHTML="";

  for(const root of folders){
    await buildTree(root,menu,true);
  }
}

/* ---------- TITLE ---------- */
function prettyTitle(name){
  return name
    .replace(".md","")
    .replace(/_/g," ")
    .replace(/-/g," ")
    .replace(/\b\w/g,l=>l.toUpperCase())
    .replace(" Ad "," AD ")
    .replace(" Gpo "," GPO ");
}

/* ---------- TREE BUILDER ---------- */
async function buildTree(path,parent,root=false){

  const url=`https://api.github.com/repos/${repo}/contents/${path}`;
  const res=await fetch(url);
  const items=await res.json();

  const folderName=path.split("/").pop();
  const folderTitle=prettyTitle(folderName);

  const folderEl=document.createElement("div");
  folderEl.className="tree-folder";
  folderEl.innerHTML=`▶ ${folderTitle}`;

  const sub=document.createElement("div");
  sub.className="tree-sub";

  folderEl.onclick=()=>{
    const open=sub.classList.toggle("open");
    folderEl.innerHTML=(open?"▼ ":"▶ ")+folderTitle;
  };

  parent.appendChild(folderEl);
  parent.appendChild(sub);

  for(const item of items){

    if(item.type==="dir"){
      await buildTree(item.path,sub);
      continue;
    }

    if(!item.name.endsWith(".md")) continue;

    const raw=item.download_url;
    const text=await fetch(raw).then(r=>r.text());

    indexCache.push({title:prettyTitle(item.name),path:raw,text});

    const file=document.createElement("button");
    file.className="tree-file";
    file.textContent="• "+prettyTitle(item.name);

    file.onclick=()=>{
      document.querySelectorAll(".tree-file").forEach(f=>f.classList.remove("active"));
      file.classList.add("active");
      openDoc(raw);
    };

    sub.appendChild(file);
  }
}

/* ---------- OPEN DOC ---------- */
function openDoc(url){
  const doc=indexCache.find(d=>d.path===url);
  if(!doc) return;

  document.getElementById("content").innerHTML=marked.parse(doc.text);
  generateTOC();
}

/* ---------- TOC ---------- */
function generateTOC(){
  const toc=document.getElementById("toc");
  toc.innerHTML="";
  const headers=document.querySelectorAll("#content h2,#content h3");

  headers.forEach(h=>{
    const id=h.textContent.toLowerCase().replace(/[^\w\s]/g,"").replace(/\s+/g,"-");
    h.id=id;

    const a=document.createElement("a");
    a.href="#"+id;
    a.textContent=h.textContent;
    toc.appendChild(a);
  });
}

/* ---------- SEARCH ---------- */
function searchDocs(){
  const q=document.getElementById("search").value.toLowerCase().trim();
  if(!q) return;

  for(const doc of indexCache){
    if(doc.text.toLowerCase().includes(q)||doc.title.toLowerCase().includes(q)){
      openDoc(doc.path);
      break;
    }
  }
}
</script>

</body>
</html>
